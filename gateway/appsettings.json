{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/identity" },
          { "RequestHeader": "X-Forwarded-By", "Set": "ApiGateway.Yarp" }
        ]
      },
      "wallet-route": {
        "ClusterId": "wallet-cluster",
        "Match": {
          "Path": "/api/wallet/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/wallet" },
          { "RequestHeader": "X-Forwarded-By", "Set": "ApiGateway.Yarp" }
        ]
      },
      "telemetry-route": {
        "ClusterId": "telemetry-cluster",
        "Match": {
          "Path": "/api/telemetry/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/telemetry" },
          { "RequestHeader": "X-Forwarded-By", "Set": "ApiGateway.Yarp" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-destination": {
            "Address": "http://localhost:5115/"
          }
        }
      },
      "wallet-cluster": {
        "Destinations": {
          "wallet-destination": {
            "Address": "http://localhost:5136/"
          }
        }
      },
      "telemetry-cluster": {
        "Destinations": {
          "telemetry-destination": {
            "Address": "http://localhost:5169/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
