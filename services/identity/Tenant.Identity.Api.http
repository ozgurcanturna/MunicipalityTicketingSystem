@Tenant.Identity.Api_HostAddress = http://localhost:5115
@tenantId = 7f4c8c0f-1d7b-4d52-8a4d-000000000001
@adminEmail = admin@ankara.local
@adminPassword = P@ssw0rd!
@adminToken = paste-admin-token-here
@operatorEmail = operator@ankara.local
@userEmail = user@ankara.local

GET {{Tenant.Identity.Api_HostAddress}}/
Accept: application/json

### Login as seeded admin
POST {{Tenant.Identity.Api_HostAddress}}/auth/login
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
	"tenantId": "{{tenantId}}",
	"email": "{{adminEmail}}",
	"password": "{{adminPassword}}"
}

### Inspect current principal
GET {{Tenant.Identity.Api_HostAddress}}/auth/me
Authorization: Bearer {{adminToken}}
X-Tenant-Id: {{tenantId}}
Accept: application/json

### Create operator user
POST {{Tenant.Identity.Api_HostAddress}}/tenants/{{tenantId}}/users
Authorization: Bearer {{adminToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
	"email": "{{operatorEmail}}",
	"fullName": "Ankara Operator",
	"password": "P@ssw0rd!",
	"role": "OPERATOR"
}

### Create user role account
POST {{Tenant.Identity.Api_HostAddress}}/tenants/{{tenantId}}/users
Authorization: Bearer {{adminToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
	"email": "{{userEmail}}",
	"fullName": "Ankara User",
	"password": "P@ssw0rd!",
	"role": "USER"
}

### Read tenant details
GET {{Tenant.Identity.Api_HostAddress}}/tenants/{{tenantId}}
Authorization: Bearer {{adminToken}}
X-Tenant-Id: {{tenantId}}
Accept: application/json
